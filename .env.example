# Self-Debrid Configuration
# Copy this file to .env and fill in your details

# Download Directory
DOWNLOAD_DIR=J:/DebridCache

# SSL Certificates
CERT_PATH=cert/cert.pem
KEY_PATH=cert/key.pem

# Network Ports
API_PORT=443
STREAM_PORT=8081

# qBittorrent Settings
USE_BITTORRENT=true
QB_HOST=localhost
QB_PORT=8080
QB_USER=admin
QB_PASS=adminadmin

# JDownloader Settings
USE_JDOWNLOADER=true
JD_EMAIL=your.email@example.com
JD_PASSWORD=your_password
JD_DEVICE=JDownloader@yourdevice

# Cache Settings
MAX_CACHE_SIZE_GB=50